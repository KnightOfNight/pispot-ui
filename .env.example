# pispot-ui environment (example)
# Copy to .env on the Pi only if you need to override defaults.
# docker-compose.yml already sets these; this file exists for reference.

LISTEN_ADDR=:443
TLS_CERT_FILE=/run/certs/fullchain.pem
TLS_KEY_FILE=/run/certs/star_private_magrathea_com.key
REQUIRE_TLS=true
AUTH_SOCKET=/run/pispot-authd.sock
AUTH_REALM=N1QZS Radio Hotspot

HOTSPOT_IF=wlan0
WAN_IF=wlan1
ADMIN_IF=eth0

PROC_PATH=/host/proc
SYS_PATH=/host/sys
LEASES_PATH=/host/dnsmasq.leases
